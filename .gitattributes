# Keep executable and CI files portable across Windows and Unix checkouts.
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.rq text eol=lf
*.ttl text eol=lf
*.svg text eol=lf

# Do not attempt textual diffs or line-ending conversion for binary assets.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
