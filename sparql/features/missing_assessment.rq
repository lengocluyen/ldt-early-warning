PREFIX ldt: <http://example.org/ldt#>

SELECT ?learner (COUNT(DISTINCT ?assessment) AS ?due_assessments) (COUNT(DISTINCT ?submittedAssessment) AS ?submitted_assessments)
WHERE {
  ?learner a ldt:Learner ;
           ldt:enrolledIn ?course .
  OPTIONAL {
    ?assessment a ldt:Assessment ;
                ldt:inCourse ?course .
  }
  OPTIONAL {
    ?learner ldt:submits ?result .
    ?result ldt:concernsAssessment ?submittedAssessment .
  }
}
GROUP BY ?learner
